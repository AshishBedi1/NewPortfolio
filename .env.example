# Contact API (Nodemailer) — used by server/index.js
# Copy to .env in project root and fill values. Restart `npm run dev` after changes.

CONTACT_API_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Gmail example: use an App Password, not your normal password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Where portfolio messages are delivered
CONTACT_TO=ashishbedi02@gmail.com
CONTACT_FROM=your@gmail.com

# Production: full URL to your deployed contact API (same origin or your backend URL)
# VITE_CONTACT_API_URL=https://yourdomain.com/api/contact
